# frozen_string_literal: true

# Gemfile for benchmarking oj_serializers with the pure-Ruby JSON gem backend.
# This Gemfile intentionally excludes oj to ensure it cannot be loaded.
# It does NOT use the gemspec (which declares oj as a dependency).
source 'https://rubygems.org'

gem 'json'
gem 'benchmark-ips'
gem 'mongoid'
gem 'activesupport'

# oj_serializers lib is loaded directly via $LOAD_PATH, not as a gem.
